# Spotify API Configuration
# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
# SPOTIFY_CLIENT_SECRET is loaded from secrets/spotify_client_secret.txt (Docker secrets)
# IMPORTANT: Update SPOTIFY_REDIRECT_URI to match your PORT setting
# Example: If PORT=8080, set SPOTIFY_REDIRECT_URI=https://localhost:8080/api/auth/spotify/callback
SPOTIFY_REDIRECT_URI=https://localhost:8000/api/auth/spotify/callback

# Application Configuration
# SECRET_KEY is loaded from secrets/secret_key.txt (Docker secrets)
# For development without Docker secrets, uncomment and set:
# SECRET_KEY=your_secret_key_here_change_in_production

# Port Configuration
# External port to expose the backend (default: 8000)
# Change this if port 8000 is already in use
# Example: PORT=8080
PORT=8000

# URLs
# Backend URL (where the FastAPI server runs)
# IMPORTANT: Update this to match your PORT setting
# Example: If PORT=8080, set BACKEND_URL=https://localhost:8080
BACKEND_URL=https://localhost:8000
# Frontend URL (for OAuth redirects and CORS)
FRONTEND_URL=https://localhost:3000

# Environment
# Options: development, production
ENVIRONMENT=development

# Persistent data directory.
# In Docker this should be a mounted volume (e.g. /data) so user state
# survives container restarts. Locally defaults to ./data.
DATA_DIR=./data
# Optional: override the system DB URL (e.g. postgresql+asyncpg://...).
# Leave blank to use a SQLite file at $DATA_DIR/pigify.db.
# SYSTEM_DATABASE_URL=
# Optional: per-user DB URL template with a {spotify_id} placeholder.
# Leave blank to use SQLite files under $DATA_DIR/users/.
# USER_DATABASE_URL_TEMPLATE=

