# Python
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.pyright/
.coverage
htmlcov/

# Node
node_modules/
dist/
.vite/

# Runtime data (the app / docker create these)
/data/
/static/
*.db
*.sqlite3

# Local environment
.env

# Local TLS certs (generated by scripts/setup-ssl.sh) — keep the dir marker
/certs/*
!/certs/.gitkeep

# Docker secret files — keep the dir marker and the README
/secrets/*
!/secrets/.gitkeep
!/secrets/README.md

# Editor / OS
.DS_Store
*.swp

# ZAP DAST scan output (only the rules file is tracked)
/.zap/*
!/.zap/baseline-rules.tsv
