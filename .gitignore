# Python
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.pyright/
.coverage
htmlcov/

# Node
node_modules/
dist/
.vite/

# Runtime data — local non-docker dev writes SQLite here (DATA_DIR default);
# keep the dir marker, ignore the databases. (Docker uses a named volume.)
/docker/data/*
!/docker/data/.gitkeep
/static/
*.db
*.sqlite3

# Local environment
.env

# Local TLS certs (generated by scripts/setup-ssl.sh) — keep the dir marker
/docker/certs/*
!/docker/certs/.gitkeep

# Docker secret files — keep the dir marker and the README
/docker/secrets/*
!/docker/secrets/.gitkeep
!/docker/secrets/README.md

# Editor / OS
.DS_Store
*.swp

# ZAP DAST scan output (only the rules file is tracked)
/.zap/*
!/.zap/baseline-rules.tsv
