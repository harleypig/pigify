# Copy to .env and fill in. Used by docker-compose.yml (and read by the
# backend via pydantic-settings). Secrets are NOT set here — they go in
# files under secrets/ (Docker secrets); see below.

# --- Spotify (required) ---
# From https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
# Must match your Spotify app's Redirect URI exactly. In the Docker stack
# TLS terminates at the frontend on port 8080:
SPOTIFY_REDIRECT_URI=https://localhost:8080/api/auth/spotify/callback

# --- Last.fm (optional) ---
# Without a key, Last.fm features are hidden (graceful degradation).
LASTFM_API_KEY=
LASTFM_SHARED_SECRET=

# --- URLs ---
BACKEND_URL=http://localhost:8000
FRONTEND_URL=https://localhost:8080

# --- Environment ---
# development | production  (production refuses the built-in SECRET_KEY)
ENVIRONMENT=development

# --- Local dev auth bypass (development only) ---
# Skip the Spotify OAuth round-trip while iterating locally so you don't
# have to log in each time. ONLY honoured when ENVIRONMENT=development — the
# backend refuses to boot if this is true in any other environment.
#   off (default): normal Spotify login.
#   on + no refresh token: a UI-only placeholder identity (DEV_SPOTIFY_ID);
#     Spotify-backed views are empty (good for chrome/layout work).
#   on + DEV_SPOTIFY_REFRESH_TOKEN: logs you in as that real Spotify account
#     (real data, no round-trip). Get the refresh token by logging in once
#     normally. Treat it like a password; never commit it.
DEV_AUTH_BYPASS=false
DEV_SPOTIFY_ID=dev-user
DEV_SPOTIFY_REFRESH_TOKEN=

# --- Built-in access gate (standalone deployments) ---
# Restrict who may use this instance without an external auth proxy. When
# enabled, only the listed Spotify account IDs can log in; enabled with an
# empty list denies everyone (fail-closed). Leave disabled if you gate
# access with a forward-auth proxy (Authelia/Authentik/oauth2-proxy/...).
# See docs/DEPLOYMENT.md. ALLOWED_SPOTIFY_IDS is comma-separated.
BUILTIN_AUTH_ENABLED=false
ALLOWED_SPOTIFY_IDS=

# --- Ports (host side) ---
FRONTEND_PORT=8080
BACKEND_PORT=8000

# --- Optional database overrides ---
# Leave blank for SQLite under the data volume ($DATA_DIR/pigify.db and
# $DATA_DIR/users/). Set to point at Postgres instead.
# SYSTEM_DATABASE_URL=
# USER_DATABASE_URL_TEMPLATE=

# --- Secrets (Docker secrets, NOT env) ---
# Create these files before `docker compose up`:
#   secrets/spotify_client_secret.txt   -> your Spotify client secret
#   secrets/secret_key.txt              -> a strong random session key
# The backend reads them via SPOTIFY_CLIENT_SECRET_FILE / SECRET_KEY_FILE
# (wired in docker-compose.yml). For local non-Docker dev you can instead
# set SPOTIFY_CLIENT_SECRET= and SECRET_KEY= directly in this .env.
