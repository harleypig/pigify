# Copy to .env and fill in. The Docker stack loads this whole file into the
# backend container (env_file in the compose file), and Compose also reads
# it to resolve ${...} in the compose files. Secrets do NOT go here — they
# are Docker secret files (see the SECRETS section at the end).
#
# COMPOSE_FILE lets `docker compose up` run from the repo root even though
# the compose file lives under docker/. Leave it set.
COMPOSE_FILE=docker/docker-compose.yml


# ====================================================================
# REQUIRED
# ====================================================================

# --- Ports (host side) — the SINGLE source of truth for the URLs ---
# FRONTEND_PORT is where your browser reaches the app (HTTPS); BACKEND_PORT
# is the backend's direct/debug port. The backend derives the Spotify
# redirect, FRONTEND_URL, BACKEND_URL, and Last.fm callback from these, so
# changing a port here updates every URL — you do NOT set them separately.
FRONTEND_PORT=8080
BACKEND_PORT=8000

# --- Spotify ---
# The client ID *and* secret are Docker secret files (see the SECRETS section
# at the end), not env vars. The redirect URI is DERIVED from FRONTEND_PORT:
#   https://127.0.0.1:<FRONTEND_PORT>/api/auth/spotify/callback
# Register that exact URI in your Spotify app's dashboard — Spotify rejects
# the login if it differs.
# IMPORTANT: use 127.0.0.1, NOT localhost — Spotify rejects localhost redirect
# URIs as insecure (2025 policy).
# Dashboard: https://developer.spotify.com/dashboard

# --- URL overrides (optional) ---
# All host URLs derive from the ports above. Override only for a non-loopback
# deploy (e.g. a real domain behind a reverse proxy):
# SPOTIFY_REDIRECT_URI=https://your-domain/api/auth/spotify/callback
# FRONTEND_URL=https://your-domain
# BACKEND_URL=https://your-domain

# --- Who may log in ---
# The built-in access gate is ON and fail-closed: with an empty allowlist
# NOBODY can log in. Add your Spotify account id (comma-separated for more).
# A denied login is logged with its id, so log in once and copy it from the
# backend logs. (Disable the gate entirely via BUILTIN_AUTH_ENABLED below
# only when an external forward-auth proxy gates access instead.)
ALLOWED_SPOTIFY_IDS=

# --- Environment ---
# development | production. The deployment compose (examples/) forces
# production regardless; this default suits local dev.
ENVIRONMENT=development


# ====================================================================
# OPTIONAL  (a fresh install needs none of this)
# ====================================================================

# --- Last.fm (scrobbling + enrichment) ---
# Leave unset and Last.fm features are hidden entirely. To enable, first
# create a Last.fm API account at https://www.last.fm/api/account/create —
# that page issues both the API key and the shared secret. Then put each in
# a file and point these at them (host paths; relative paths resolve against
# the compose dir). They are mounted as Docker secrets, so the values never
# sit in the container environment. (See docs/INTEGRATIONS.md › Last.fm.)
# LASTFM_API_KEY_FILE=./secrets/lastfm_api_key.txt
# LASTFM_SHARED_SECRET_FILE=./secrets/lastfm_shared_secret.txt
# LASTFM_CALLBACK_URI=https://127.0.0.1:8080/api/integrations/lastfm/callback

# --- Access gate toggle ---
# Leave ON (default). Set false ONLY when an external forward-auth proxy
# (Authelia/Authentik/oauth2-proxy/...) gates access. See docs/DEPLOYMENT.md.
# BUILTIN_AUTH_ENABLED=true

# --- Database ---
# Leave blank for SQLite under the data volume — the recommended (and only
# supported) setup. Spotify's Dev-Mode 5-user cap puts Postgres-scale load
# out of reach, so Postgres is deferred until Extended Quota Mode and these
# stay unset; the URL-swap is latent only. See docs/adr/0003-*.
# SYSTEM_DATABASE_URL=
# USER_DATABASE_URL_TEMPLATE=

# --- Compose / runtime knobs ---
# Host locations of the secret files and TLS certs (relative paths resolve
# against the compose dir; default to docker/secrets and docker/certs).
# RESTART_POLICY controls container restarts; PIGIFY_VERSION pins the image
# tag for the deployment compose.
# SECRETS_DIR=./secrets
# CERTS_DIR=./certs
# RESTART_POLICY=unless-stopped
# PIGIFY_VERSION=latest

# --- Local development only ---
# Skip the Spotify OAuth round-trip while iterating locally. ONLY honoured
# when ENVIRONMENT=development — the backend refuses to boot if true in any
# other environment. Placeholder mode (no refresh token) gives a UI-only
# identity; with DEV_SPOTIFY_REFRESH_TOKEN it logs you in as that real
# account. Treat the refresh token like a password; never commit it.
# DEV_AUTH_BYPASS=false
# DEV_SPOTIFY_ID=dev-user
# DEV_SPOTIFY_REFRESH_TOKEN=


# ====================================================================
# SECRETS & FILE-SOURCED CONFIG  (file OR this .env; file wins)
# ====================================================================
# Every sensitive value can come either directly from this .env or from a
# file via a matching *_FILE pointer (the file wins when set + non-empty).
# In the Docker stack the backend reads files at /run/secrets/<name>; set a
# *_FILE var to a host path to use a Docker secret, or just set the plain
# value here.
#
#   secret_key.txt is the one still wired as a *required* Docker secret in
#   the compose (SECRETS_DIR, default docker/secrets/):
#       python3 -c "import secrets;print(secrets.token_urlsafe(32))"
#   — or set SECRET_KEY= here / SECRET_KEY_FILE= at a host file.
#
# Spotify client id/secret: set them here, OR point SPOTIFY_CLIENT_ID_FILE= /
# SPOTIFY_CLIENT_SECRET_FILE= at host files. Production refuses to boot if
# neither source provides them.
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
#
# Last.fm (optional): LASTFM_API_KEY= / LASTFM_SHARED_SECRET= here, or the
# matching *_FILE pointers.
#
# Non-secret config is also file-sourceable (file wins) for uniform
# provisioning: ALLOWED_SPOTIFY_IDS_FILE=, DEV_SPOTIFY_ID_FILE=,
# DEV_SPOTIFY_REFRESH_TOKEN_FILE=.
